\@writefile{lof}{\contentsline {figure}{\numberline {SI-3}{\ignorespaces \textbf  {{\color {blue}\uwave {Pre-/Post-Covid Courses}}}{\color {blue}\uwave {. Number of courses per CIP field (gray) in thirty-three European countries before and after Covid-19. Data from Open Syllabus (2017-2022). Smooth trend curves show the average pattern per broad field definition (ISCED-F). Most fields exhibit a significant drop in courses during the pandemic, especially Health and Welfare, Arts and Humanities, and Social Sciences and Journalism.}}\relax }}{44}{figure.caption.22}\protected@file@percent }
\newlabel{fig:covid-trend}{{SI-3}{44}{\textbf {\DIFaddFL {Pre-/Post-Covid Courses}}\DIFaddFL {. Number of courses per CIP field (gray) in thirty-three European countries before and after Covid-19. Data from Open Syllabus (2017-2022). Smooth trend curves show the average pattern per broad field definition (ISCED-F). Most fields exhibit a significant drop in courses during the pandemic, especially Health and Welfare, Arts and Humanities, and Social Sciences and Journalism.}\relax }{figure.caption.22}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {SI-4}{\ignorespaces \textbf  {{\color {blue}\uwave {Heterogeneity within US courses}}}{\color {blue}\uwave {. Estimates and 95\% confidence intervals for differences in (1) interdisciplinarity (2) readings' conventionality (3) age of readings (4) female-authored ratio and (5) readings' atypicality. Estimates are from separate mixed-effects regressions for courses from the US vs the full sample, in each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates. The comparison reveals no noticeable differences.}}\relax }}{45}{figure.caption.23}\protected@file@percent }
\newlabel{fig:hetero-us-plots}{{SI-4}{45}{\textbf {\DIFaddFL {Heterogeneity within US courses}}\DIFaddFL {. Estimates and 95\% confidence intervals for differences in (1) interdisciplinarity (2) readings' conventionality (3) age of readings (4) female-authored ratio and (5) readings' atypicality. Estimates are from separate mixed-effects regressions for courses from the US vs the full sample, in each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates. The comparison reveals no noticeable differences.}\relax }{figure.caption.23}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {SI-5}{\ignorespaces \textbf  {{\color {blue}\uwave {Robustness analysis for interdisciplinarity.}}} {\color {blue}\uwave {Estimates and 95\% confidence intervals from a multiple linear regression on the full sample. Dependent variable = percentile rank per year of interdisciplinarity score. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}}\relax }}{46}{figure.caption.24}\protected@file@percent }
\newlabel{fig:robust-interdisc}{{SI-5}{46}{\textbf {\DIFaddFL {Robustness analysis for interdisciplinarity.}} \DIFaddFL {Estimates and 95\% confidence intervals from a multiple linear regression on the full sample. Dependent variable = percentile rank per year of interdisciplinarity score. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}\relax }{figure.caption.24}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {SI-6}{\ignorespaces \textbf  {{\color {blue}\uwave {Robustness analysis for female-authored readings.}}} {\color {blue}\uwave {Estimates and 95\% confidence intervals from (A) a multiple linear regression (B) quasi-poisson regression on the full sample. Dependent variable = fraction of female-authored readings to toal readings. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}}\relax }}{47}{figure.caption.25}\protected@file@percent }
\newlabel{fig:robust-women}{{SI-6}{47}{\textbf {\DIFaddFL {Robustness analysis for female-authored readings.}} \DIFaddFL {Estimates and 95\% confidence intervals from (A) a multiple linear regression (B) quasi-poisson regression on the full sample. Dependent variable = fraction of female-authored readings to toal readings. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}\relax }{figure.caption.25}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {SI-7}{\ignorespaces \textbf  {{\color {blue}\uwave {Robustness analysis for age of readings.}}} {\color {blue}\uwave {Estimates and 95\% confidence intervals from a multiple linear regression on the full sample. Dependent variable = percentile rank of the age of publication of a syllabus' readings as (A) percentile rank per year (B) logarithm. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}}\relax }}{48}{figure.caption.26}\protected@file@percent }
\newlabel{fig:robust-age-readings}{{SI-7}{48}{\textbf {\DIFaddFL {Robustness analysis for age of readings.}} \DIFaddFL {Estimates and 95\% confidence intervals from a multiple linear regression on the full sample. Dependent variable = percentile rank of the age of publication of a syllabus' readings as (A) percentile rank per year (B) logarithm. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}\relax }{figure.caption.26}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {SI-8}{\ignorespaces \textbf  {{\color {blue}\uwave {Robustness analysis for conventionality of readings.}}} {\color {blue}\uwave {Estimates and 95\% confidence intervals from a multiple linear regression on the full sample. Dependent variable = median citations of a syllabus' readings as from references in previous syllabi as (A) percentile rank per year (B) logarithm. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}}\relax }}{49}{figure.caption.27}\protected@file@percent }
\newlabel{fig:robust-conventional}{{SI-8}{49}{\textbf {\DIFaddFL {Robustness analysis for conventionality of readings.}} \DIFaddFL {Estimates and 95\% confidence intervals from a multiple linear regression on the full sample. Dependent variable = median citations of a syllabus' readings as from references in previous syllabi as (A) percentile rank per year (B) logarithm. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}\relax }{figure.caption.27}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {SI-9}{\ignorespaces \textbf  {{\color {blue}\uwave {Robustness analysis for atypicality of readings.}}} {\color {blue}\uwave {Estimates and 95\% confidence intervals from a multiple linear regression on the full sample. Dependent variable = median Uzzi et al's atypicality of a syllabus' readings as precomputed by SciSciNet v2 as (A) percentile rank per year (B) logarithm. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}}\relax }}{50}{figure.caption.28}\protected@file@percent }
\newlabel{fig:robust-atypical}{{SI-9}{50}{\textbf {\DIFaddFL {Robustness analysis for atypicality of readings.}} \DIFaddFL {Estimates and 95\% confidence intervals from a multiple linear regression on the full sample. Dependent variable = median Uzzi et al's atypicality of a syllabus' readings as precomputed by SciSciNet v2 as (A) percentile rank per year (B) logarithm. Controls include the country, year, the probability of the document being a proper syllabus, field of study, institution, course levels, and (logarithm of) the number of matched readings.}\relax }{figure.caption.28}{}}
