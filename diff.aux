\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces \DIFdelbeginFL  {\color {red}\sout {This figure plots the yearly difference }}\DIFdelendFL  \DIFaddbeginFL  \textbf  {{\color {blue}\uwave {Female-Authored Radings Ratio}}}{\color {blue}\uwave {. Estimates and 95\% confidence intervals for differences }}\DIFaddendFL  in \DIFdelbeginFL  {\color {red}\sout {the share of female-authored readings relative to }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {Female-authored radings ratio between }}\DIFaddendFL  courses taught by \DIFdelbeginFL  {\color {red}\sout {a single male instructor }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {men alone }}\DIFaddendFL  (\DIFdelbeginFL  {\color {red}\sout {baseline = 0}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {reference}}\DIFaddendFL  ) \DIFdelbeginFL  {\color {red}\sout {, for each team configuration. The values are regression coefficients obtained separately for each academic year, with controls for country }}\DIFdelendFL  and \DIFdelbeginFL  {\color {red}\sout {field}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {courses taught by other instructor teams}}\DIFaddendFL  . \DIFdelbeginFL  {\color {red}\sout {The outcome }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {This variable }}\DIFaddendFL  is the \DIFdelbeginFL  {\color {red}\sout {percentage-point gap in the }}\DIFdelendFL  proportion of female authors cited in the course readings\DIFdelbeginFL  {\color {red}\sout {; positive values}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {. Estimates are from separate mixed-effects regressions for each academic year}}\DIFaddendFL  , \DIFdelbeginFL  {\color {red}\sout {therefore}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {controlling for country}}\DIFaddendFL  , \DIFdelbeginFL  {\color {red}\sout {indicate }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {field, institution, course level, probability that the document is }}\DIFaddendFL  a \DIFdelbeginFL  {\color {red}\sout {larger share }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {syllabus, and number }}\DIFaddendFL  of \DIFdelbeginFL  {\color {red}\sout {female authors over total authors associated }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {readings, }}\DIFaddendFL  with \DIFdelbeginFL  {\color {red}\sout {a given team configuration in that year}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {weights proportional to the square root of the number of readings}}\DIFaddendFL  . \DIFdelbeginFL  {\color {red}\sout {The shaded area represents 95\% confidence intervals}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates}}\DIFaddendFL  .\relax }}{27}{figure.caption.9}\protected@file@percent }
\newlabel{fig:female-authors}{{8}{27}{\DIFdelbeginFL \DIFdelFL {This figure plots the yearly difference }\DIFdelendFL \DIFaddbeginFL \textbf {\DIFaddFL {Female-Authored Radings Ratio}}\DIFaddFL {. Estimates and 95\% confidence intervals for differences }\DIFaddendFL in \DIFdelbeginFL \DIFdelFL {the share of female-authored readings relative to }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {Female-authored radings ratio between }\DIFaddendFL courses taught by \DIFdelbeginFL \DIFdelFL {a single male instructor }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {men alone }\DIFaddendFL (\DIFdelbeginFL \DIFdelFL {baseline = 0}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {reference}\DIFaddendFL ) \DIFdelbeginFL \DIFdelFL {, for each team configuration. The values are regression coefficients obtained separately for each academic year, with controls for country }\DIFdelendFL and \DIFdelbeginFL \DIFdelFL {field}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {courses taught by other instructor teams}\DIFaddendFL . \DIFdelbeginFL \DIFdelFL {The outcome }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {This variable }\DIFaddendFL is the \DIFdelbeginFL \DIFdelFL {percentage-point gap in the }\DIFdelendFL proportion of female authors cited in the course readings\DIFdelbeginFL \DIFdelFL {; positive values}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {. Estimates are from separate mixed-effects regressions for each academic year}\DIFaddendFL , \DIFdelbeginFL \DIFdelFL {therefore}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {controlling for country}\DIFaddendFL , \DIFdelbeginFL \DIFdelFL {indicate }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {field, institution, course level, probability that the document is }\DIFaddendFL a \DIFdelbeginFL \DIFdelFL {larger share }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {syllabus, and number }\DIFaddendFL of \DIFdelbeginFL \DIFdelFL {female authors over total authors associated }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {readings, }\DIFaddendFL with \DIFdelbeginFL \DIFdelFL {a given team configuration in that year}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {weights proportional to the square root of the number of readings}\DIFaddendFL . \DIFdelbeginFL \DIFdelFL {The shaded area represents 95\% confidence intervals}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates}\DIFaddendFL .\relax }{figure.caption.9}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces \textbf  {{\color {blue}\uwave {Age of Readings by Team}}}{\color {blue}\uwave {. Estimates and 95\% confidence intervals for differences in Age of Readings between courses taught by men alone (reference) and courses taught by other instructor teams. Age of Readings is the percentile rank, within a given year, of a syllabus' average publication age of the readings. Estimates are from separate mixed-effects regressions for each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates.}}\relax }}{28}{figure.caption.10}\protected@file@percent }
\newlabel{fig:age-readings}{{9}{28}{\textbf {\DIFaddFL {Age of Readings by Team}}\DIFaddFL {. Estimates and 95\% confidence intervals for differences in Age of Readings between courses taught by men alone (reference) and courses taught by other instructor teams. Age of Readings is the percentile rank, within a given year, of a syllabus' average publication age of the readings. Estimates are from separate mixed-effects regressions for each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates.}\relax }{figure.caption.10}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces \textbf  {{\color {blue}\uwave {Readings Conventionality by Team}}}{\color {blue}\uwave {. Estimates and 95\% confidence intervals for differences in Teaching Conventionality between courses taught by men alone (reference) and courses taught by other instructor teams. Teaching Conventionality is the percentile rank, within a given year, of a syllabus' median citations of readings, based on references from other syllabi. Estimates are from separate mixed-effects regressions for each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates.}}\relax }}{29}{figure.caption.11}\protected@file@percent }
\newlabel{fig:conventionality}{{10}{29}{\textbf {\DIFaddFL {Readings Conventionality by Team}}\DIFaddFL {. Estimates and 95\% confidence intervals for differences in Teaching Conventionality between courses taught by men alone (reference) and courses taught by other instructor teams. Teaching Conventionality is the percentile rank, within a given year, of a syllabus' median citations of readings, based on references from other syllabi. Estimates are from separate mixed-effects regressions for each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates.}\relax }{figure.caption.11}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces \textbf  {{\color {blue}\uwave {Scientific Novelty by Team}}}{\color {blue}\uwave {. Estimates and 95\% confidence intervals for differences in Scientific Novelty between courses taught by men alone (reference) and courses taught by other instructor teams. Scientific Novelty is the percentile rank, within a given year, of a syllabus' median Uzzi et al's atypicality of readings, based on the combination of references in the readings. Estimates are from separate mixed-effects regressions for each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates.}}\relax }}{30}{figure.caption.12}\protected@file@percent }
\newlabel{fig:atypicality}{{11}{30}{\textbf {\DIFaddFL {Scientific Novelty by Team}}\DIFaddFL {. Estimates and 95\% confidence intervals for differences in Scientific Novelty between courses taught by men alone (reference) and courses taught by other instructor teams. Scientific Novelty is the percentile rank, within a given year, of a syllabus' median Uzzi et al's atypicality of readings, based on the combination of references in the readings. Estimates are from separate mixed-effects regressions for each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates.}\relax }{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \textbf  {{\color {blue}\uwave {Heterogeneity within STEM Fields}}}{\color {blue}\uwave {. Estimates and 95\% confidence intervals for differences in (1) interdisciplinarity (2) readings' conventionality (3) age of readings (4) female-authored ratio and (5) readings' atypicality. Estimates are from separate mixed-effects regressions for STEM fields vs the full sample, in each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates.}}\relax }}{31}{figure.caption.13}\protected@file@percent }
\newlabel{fig:stem}{{12}{31}{\textbf {\DIFaddFL {Heterogeneity within STEM Fields}}\DIFaddFL {. Estimates and 95\% confidence intervals for differences in (1) interdisciplinarity (2) readings' conventionality (3) age of readings (4) female-authored ratio and (5) readings' atypicality. Estimates are from separate mixed-effects regressions for STEM fields vs the full sample, in each academic year, controlling for country, field, institution, course level, probability that the document is a syllabus, and number of readings, with weights proportional to the square root of the number of readings. Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates.}\relax }{figure.caption.13}{}}
