\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Evolution of Teaching Teams by Gender Composition and Size. Trends in course gender composition from 2000 to 2019 reveal a steady increase in women's participation (both in solo-taught and two-instructor courses), while the proportion of mixed-gender teams has remained relatively stable over time. (A) Percentage of solo-taught courses by instructor gender over time. (B) Percentage of two-instructor courses by gender composition over time. N = 5.1 million courses. The shaded area represents 95\% confidence interval of the proportion per academic year.\relax }}{20}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:team-trends}{{1}{20}{Evolution of Teaching Teams by Gender Composition and Size. Trends in course gender composition from 2000 to 2019 reveal a steady increase in women's participation (both in solo-taught and two-instructor courses), while the proportion of mixed-gender teams has remained relatively stable over time. (A) Percentage of solo-taught courses by instructor gender over time. (B) Percentage of two-instructor courses by gender composition over time. N = 5.1 million courses. The shaded area represents 95\% confidence interval of the proportion per academic year.\relax }{figure.caption.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Comparison of gender composition between actual courses and courses simulated with Monte Carlo. Simulations ensure gender neutrality while keeping constant institutional constraints (i.e., number of teams by size, institution, academic year, and 69 academic fields). Simulated mixed-gender teams consistently exceed observed proportions, highlighting persistent barriers to forming gender-diverse teaching teams.\relax }}{21}{figure.caption.3}\protected@file@percent }
\newlabel{fig:montecarlo}{{2}{21}{Comparison of gender composition between actual courses and courses simulated with Monte Carlo. Simulations ensure gender neutrality while keeping constant institutional constraints (i.e., number of teams by size, institution, academic year, and 69 academic fields). Simulated mixed-gender teams consistently exceed observed proportions, highlighting persistent barriers to forming gender-diverse teaching teams.\relax }{figure.caption.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces This figure disaggregates the comparison of proportions between actual (green) and simulated (orange) mixed-gender (MF/FM) courses by academic field. The shaded bar indicates a 95\% confidence level of the proportion.\relax }}{22}{figure.caption.4}\protected@file@percent }
\newlabel{fig:montecarlo-by-field}{{3}{22}{This figure disaggregates the comparison of proportions between actual (green) and simulated (orange) mixed-gender (MF/FM) courses by academic field. The shaded bar indicates a 95\% confidence level of the proportion.\relax }{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces This figure disaggregates the comparison of proportions between actual (green) and simulated (orange) mixed-gender courses (MF/FM) by country. Simulated mixed-gender teams consistently exceed observed proportions in all countries. EU countries are Austria, Denmark, France, Germany, Ireland, Italy, Netherlands, Poland, Portugal, Spain and Sweden.\relax }}{23}{figure.caption.5}\protected@file@percent }
\newlabel{fig:montecarlo-by-cntry}{{4}{23}{This figure disaggregates the comparison of proportions between actual (green) and simulated (orange) mixed-gender courses (MF/FM) by country. Simulated mixed-gender teams consistently exceed observed proportions in all countries. EU countries are Austria, Denmark, France, Germany, Ireland, Italy, Netherlands, Poland, Portugal, Spain and Sweden.\relax }{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {{\color {blue}\uwave {Team composition post-Covid-19 change}}}{\color {blue}\uwave {. Coefficients and 95\% confidence intervals for post-covid period obtained from the following Binomial regressions: (a) probability of single teams being taught by a woman vs man; (b) probability of teams being composed by one instructor vs multiple (teaching collaboration); (c) probability of teaching teams being mixed-gender vs.~same-gender collaborations. All regressions are based on 2.2M syllabi from institutions in thirty-three European countries (excluding teams with three or more collaborations, and authors of unknown gender).}}\relax }}{24}{figure.caption.6}\protected@file@percent }
\newlabel{fig:covid-coeffs}{{5}{24}{\textbf {\DIFaddFL {Team composition post-Covid-19 change}}\DIFaddFL {. Coefficients and 95\% confidence intervals for post-covid period obtained from the following Binomial regressions: (a) probability of single teams being taught by a woman vs man; (b) probability of teams being composed by one instructor vs multiple (teaching collaboration); (c) probability of teaching teams being mixed-gender vs.~same-gender collaborations. All regressions are based on 2.2M syllabi from institutions in thirty-three European countries (excluding teams with three or more collaborations, and authors of unknown gender).}\relax }{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {{\color {blue}\uwave {Post-Pandemic Team Formation}}}{\color {blue}\uwave {. Simulated gender-neutral vs observed teaching teams for 2.2M syllabi from institutions in thirty-three European countries. Covid-19 period highlighted (2020-2021). This shows that the gap between mixed-gender and same-gender collaborations widens after Covid.}}\relax }}{25}{figure.caption.7}\protected@file@percent }
\newlabel{fig:covid-simulations}{{6}{25}{\textbf {\DIFaddFL {Post-Pandemic Team Formation}}\DIFaddFL {. Simulated gender-neutral vs observed teaching teams for 2.2M syllabi from institutions in thirty-three European countries. Covid-19 period highlighted (2020-2021). This shows that the gap between mixed-gender and same-gender collaborations widens after Covid.}\relax }{figure.caption.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces \DIFdelbeginFL  {\color {red}\sout {This figure illustrates the yearly difference }}\DIFdelendFL  \DIFaddbeginFL  \textbf  {{\color {blue}\uwave {Interdisciplinarity}}}{\color {blue}\uwave {. Estimates and 95\% confidence intervals for differences }}\DIFaddendFL  in \DIFdelbeginFL  {\color {red}\sout {interdisciplinarity relative to }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {Interdisciplinarity between }}\DIFaddendFL  courses taught by \DIFdelbeginFL  {\color {red}\sout {a single male instructor }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {men alone }}\DIFaddendFL  (\DIFdelbeginFL  {\color {red}\sout {baseline = 0}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {reference}}\DIFaddendFL  ) \DIFdelbeginFL  {\color {red}\sout {for each team configuration. The values are regression coefficients obtained separately for each academic year, with controls for country }}\DIFdelendFL  and \DIFdelbeginFL  {\color {red}\sout {field}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {courses taught by other instructor teams}}\DIFaddendFL  . Interdisciplinarity is the percentile rank\DIFaddbeginFL  {\color {blue}\uwave {, within a given year, }}\DIFaddendFL  of \DIFdelbeginFL  {\color {red}\sout {each course’s }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {a syllabus' }}\DIFaddendFL  interdisciplinarity score \DIFdelbeginFL  {\color {red}\sout {within }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {based on }}\DIFaddendFL  its \DIFdelbeginFL  {\color {red}\sout {cohort; positive values}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {textual description relative to other syllabi. Estimates are from separate mixed-effects regressions for each academic year}}\DIFaddendFL  , \DIFdelbeginFL  {\color {red}\sout {therefore}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {controlling for country}}\DIFaddendFL  , \DIFdelbeginFL  {\color {red}\sout {indicate }}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {field, institution, course level, probability that the document is }}\DIFaddendFL  a \DIFdelbeginFL  {\color {red}\sout {greater interdisciplinarity}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {syllabus, and number of readings, with weights proportional to the square root of the number of readings}}\DIFaddendFL  . \DIFdelbeginFL  {\color {red}\sout {The shaded area represents 95\% confidence intervals}}\DIFdelendFL  \DIFaddbeginFL  {\color {blue}\uwave {Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates}}\DIFaddendFL  .\relax }}{26}{figure.caption.8}\protected@file@percent }
\newlabel{fig:interdisciplinarity}{{7}{26}{\DIFdelbeginFL \DIFdelFL {This figure illustrates the yearly difference }\DIFdelendFL \DIFaddbeginFL \textbf {\DIFaddFL {Interdisciplinarity}}\DIFaddFL {. Estimates and 95\% confidence intervals for differences }\DIFaddendFL in \DIFdelbeginFL \DIFdelFL {interdisciplinarity relative to }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {Interdisciplinarity between }\DIFaddendFL courses taught by \DIFdelbeginFL \DIFdelFL {a single male instructor }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {men alone }\DIFaddendFL (\DIFdelbeginFL \DIFdelFL {baseline = 0}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {reference}\DIFaddendFL ) \DIFdelbeginFL \DIFdelFL {for each team configuration. The values are regression coefficients obtained separately for each academic year, with controls for country }\DIFdelendFL and \DIFdelbeginFL \DIFdelFL {field}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {courses taught by other instructor teams}\DIFaddendFL . Interdisciplinarity is the percentile rank\DIFaddbeginFL \DIFaddFL {, within a given year, }\DIFaddendFL of \DIFdelbeginFL \DIFdelFL {each course’s }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {a syllabus' }\DIFaddendFL interdisciplinarity score \DIFdelbeginFL \DIFdelFL {within }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {based on }\DIFaddendFL its \DIFdelbeginFL \DIFdelFL {cohort; positive values}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {textual description relative to other syllabi. Estimates are from separate mixed-effects regressions for each academic year}\DIFaddendFL , \DIFdelbeginFL \DIFdelFL {therefore}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {controlling for country}\DIFaddendFL , \DIFdelbeginFL \DIFdelFL {indicate }\DIFdelendFL \DIFaddbeginFL \DIFaddFL {field, institution, course level, probability that the document is }\DIFaddendFL a \DIFdelbeginFL \DIFdelFL {greater interdisciplinarity}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {syllabus, and number of readings, with weights proportional to the square root of the number of readings}\DIFaddendFL . \DIFdelbeginFL \DIFdelFL {The shaded area represents 95\% confidence intervals}\DIFdelendFL \DIFaddbeginFL \DIFaddFL {Smoothed curves show local estimates averaged across years, weighted by the precision (standard errors) of the estimates}\DIFaddendFL .\relax }{figure.caption.8}{}}
